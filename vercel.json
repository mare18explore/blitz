{
  "rewrites": [
    {
    "source": "/api/espn-site/:path*",
    "destination": "https://site.api.espn.com/:path*"
    },
    
    {
      "source": "/api/espn/:path*",
      "destination": "https://sports.core.api.espn.com/:path*"
    },
    {
      "source": "/api/gemini/:path*",
      "destination": "https://generativelanguage.googleapis.com/:path*"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Forwarded-Proto",
          "value": "https"
        }
      ]
    }
  ]
}